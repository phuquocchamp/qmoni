{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Token Usage",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total[5m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "stacking": { "mode": "normal" } }
    },
    {
      "title": "Session Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(claude_code_cost_usage_USD_total)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "red", "value": 5 }
        ]}}
      }
    },
    {
      "title": "Cost Over Time",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(claude_code_cost_usage_USD_total[5m]))",
          "legendFormat": "Cost/min"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(claude_code_session_count_total)"
        }
      ]
    },
    {
      "title": "Active Time",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (type) (rate(claude_code_active_time_total_seconds_total[5m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Lines of Code",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (type) (claude_code_lines_of_code_count_total)",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "title": "Commits",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(claude_code_commit_count_total)"
        }
      ]
    },
    {
      "title": "Pull Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(claude_code_pull_request_count_total)"
        }
      ]
    },
    {
      "title": "Cache Efficiency",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m])) / (sum(rate(claude_code_token_usage_tokens_total{type=\"input\"}[5m])) + sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "green", "value": 0.6 }
          ]}
        }
      }
    },
    {
      "title": "Token Usage by Model",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (claude_code_token_usage_tokens_total)",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "title": "Tool Usage (Events)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=\"claude-code\"} | json | event_name=\"claude_code.tool_result\" | line_format \"{{.tool_name}}\"",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "API Latency Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=\"claude-code\"} | json | event_name=\"claude_code.api_request\" | unwrap duration_ms | __error__=\"\""
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["claude-code", "telemetry"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Claude Code — Live Report",
  "uid": "claude-code-live-report",
  "version": 1
}
